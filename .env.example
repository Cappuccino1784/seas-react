# SEAS Website Environment Variables

# Public site URL (optional)
NEXT_PUBLIC_SITE_URL=https://seas.example.com

# Contact Email (optional)
NEXT_PUBLIC_CONTACT_EMAIL=contact@seas.example.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Protect CSV export route: /api/applications/export?token=...
APPLICATION_EXPORT_TOKEN=replace-with-a-long-random-string
